model AppOrder {
  id          String   @id @default(uuid()) @db.UniqueIdentifier
  tableId     Int
  status      String   @default("open") @db.NVarChar(20)
  billingMode String   @db.NVarChar(20)
  clientId    String?  @db.NVarChar(20) // Maint_Clientes.Cliente_Id
  clientName  String?  @db.NVarChar(80)
  beneficiary String?  @db.NVarChar(100)
  createdByUserId String? @db.NVarChar(20) // Maint_Users.User_Id
  createdAt   DateTime @default(now()) @db.DateTime
  updatedAt   DateTime @updatedAt @db.DateTime

  accounts AppOrderAccount[]
  items    AppOrderItem[]
  invoices AppInvoice[]

  @@index([tableId, status])
  @@map("App_Orders")
}

model AppOrderAccount {
  id        String   @id @default(uuid()) @db.UniqueIdentifier
  orderId   String   @db.UniqueIdentifier
  key       String   @db.NVarChar(10) // "A", "B", ...
  name      String   @db.NVarChar(100)
  createdAt DateTime @default(now()) @db.DateTime

  order  AppOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items  AppOrderItem[]
  splits AppInvoiceSplit[]

  @@unique([orderId, key])
  @@index([orderId])
  @@map("App_OrderAccounts")
}

model AppOrderItem {
  id          String   @id @default(uuid()) @db.UniqueIdentifier
  orderId     String   @db.UniqueIdentifier
  accountId   String   @db.UniqueIdentifier
  productId   String   @db.NVarChar(20) // Maint_Inventario.Art_ID
  productName String   @db.NVarChar(150)
  unitPrice   Decimal  @db.Decimal(28, 6) // DOP
  qty         Int
  note        String?  @db.NVarChar(250) @map("Note")
  itemStatus  String   @default("pending") @db.NVarChar(20)
  createdAt   DateTime @default(now()) @db.DateTime
  updatedAt   DateTime @updatedAt @db.DateTime

  // NoAction here to avoid multiple cascade paths (order -> account -> item already cascades).
  order   AppOrder        @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  account AppOrderAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([orderId, accountId, productId])
  @@index([orderId])
  @@map("App_OrderItems")
}

// Catalog table for order item statuses (drives labels/colors in the app).
model AppOrderItemStatus {
  code      String  @id @db.NVarChar(20) // e.g. "pending" | "in_progress" | "completed"
