  amount    Decimal  @db.Decimal(28, 2)
  percent   Decimal? @db.Decimal(28, 6)

  invoice AppInvoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // NoAction here to avoid multiple cascade paths (order -> invoice -> split already cascades).
  account AppOrderAccount  @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([invoiceId])
  @@index([accountId])
  @@map("App_InvoiceSplits")
}

// Catalog table for order statuses (drives labels/colors in the app).
model AppOrderStatus {
  code        String  @id @db.NVarChar(20) // "open" | "paid" | "cleaning" | "closed"
  label       String  @db.NVarChar(50) // Display label
  tableStatus String  @db.NVarChar(20) // "occupied" | "pending" | "cleaning" | "available"
  color       String? @db.NVarChar(20)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  @@map("App_OrderStatuses")
}

// Key/value settings used by the backend and app (default client, images folder, etc).
model AppSetting {
  key       String   @id @map("SettingKey") @db.NVarChar(100)
  value     String?  @map("SettingValue") @db.NVarChar(Max)
  createdAt DateTime @default(now()) @map("CreatedAt") @db.DateTime
  updatedAt DateTime @updatedAt @map("UpdatedAt") @db.DateTime

  @@map("App_Settings")
}

// Dining tables (drives the table grid in the app).
model AppTable {
  id        Int      @id @map("TableId")
  seats     Int      @default(4) @map("Seats")
  section   String?  @map("Section") @db.NVarChar(50)
  sortOrder Int      @default(0) @map("SortOrder")
  isActive  Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt") @db.DateTime
  updatedAt DateTime @updatedAt @map("UpdatedAt") @db.DateTime

  @@index([isActive, sortOrder])
  @@map("App_Tables")
}
