generator client {
  provider      = "prisma-client-js"
  // Necesario porque el despliegue en Site4Now/HostBuddy corre en Windows,
  // pero el generate se hace desde macOS (darwin-arm64).
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

