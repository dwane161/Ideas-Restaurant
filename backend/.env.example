PORT=3001
# Ejemplo para SQL Server (ajusta host/puerto/db/credenciales y TLS):
# Nota: Prisma NO usa `jdbc:sqlserver://...` (si lo pones te dará P1013). Debe empezar con `sqlserver://`.
# Si tu password contiene `;` o `=`, debes escaparlo (URL-encode), porque `;` separa propiedades.
# DATABASE_URL="sqlserver://localhost:1433;database=ideas_restaurant;user=sa;password=YourStrong!Passw0rd;encrypt=true;trustServerCertificate=true"
DATABASE_URL="sqlserver://localhost:1433;database=ideas_restaurant;user=sa;password=CHANGE_ME;encrypt=true;trustServerCertificate=true"
CORS_ORIGIN="http://localhost:4200"
