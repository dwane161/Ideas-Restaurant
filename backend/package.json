{
  "name": "ideas-restaurant-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "prisma": "prisma",
    "generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:push": "prisma db push",
    "db:diff": "prisma migrate diff --from-schema-datasource prisma/schema.prisma --to-schema-datamodel prisma/schema.prisma --script",
    "db:diff:empty": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "studio": "prisma studio",
    "migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "prisma": "^6.16.0",
    "tsx": "^4.20.5",
    "typescript": "~5.9.0"
  }
}
